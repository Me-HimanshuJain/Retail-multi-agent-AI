# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=intermediate

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — works out of the box, no setup needed)
DATABASE_URL=sqlite:///./retail.db
# PostgreSQL (uncomment and fill in for production)
# DATABASE_URL=postgresql://retail:<password>@localhost:5432/retail_db

# ── PostgreSQL credentials (used by docker-compose.yml) ───────────────────────
POSTGRES_USER=retail
# CHANGE THIS — never commit a real password
POSTGRES_PASSWORD=<change-this-before-use>
POSTGRES_DB=retail_db

# ── Redis (optional) ──────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED — the app will refuse to start with the default value below.
# Generate a secure key (run once, paste the output here):
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-and-paste-here>

JWT_ALGORITHM=HS256
# Access token lifetime in minutes (P1: reduced from 1440 to 30)
JWT_EXPIRATION_MINUTES=30

# Refresh token lifetime in seconds (P1: 7 days = 604800)
# Clients exchange the refresh token for a new access+refresh pair via POST /auth/refresh
REFRESH_TOKEN_TTL_SECONDS=604800

# CORS — comma-separated list of allowed frontend origins (P1)
# Production: replace with your actual frontend URL(s)
# The Streamlit dashboard defaults (localhost) are included by default.
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── Bootstrap users ───────────────────────────────────────────────────────────
# JSON array of {username, role, hashed_password} objects.
# hashed_password must be a bcrypt hash — NEVER the plaintext password.
#
# Generate a bcrypt hash for a password (run for each user):
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt(rounds=12)).decode())"
#
# Example (replace the $2b$12$... placeholders with real hashes):
# BOOTSTRAP_USERS_JSON=[{"username":"admin","role":"admin","hashed_password":"$2b$12$REPLACE_WITH_REAL_HASH"},{"username":"viewer","role":"viewer","hashed_password":"$2b$12$REPLACE_WITH_REAL_HASH"}]
BOOTSTRAP_USERS_JSON=[]

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
# CHANGE THIS — never commit a real password
MINIO_ROOT_PASSWORD=<change-this-before-use>

# ── MLflow (optional) ─────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=retail_multi_agent

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
