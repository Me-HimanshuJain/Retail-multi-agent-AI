# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=intermediate

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — works out of the box, no setup needed)
DATABASE_URL=sqlite:///./retail.db
# PostgreSQL (optional — uncomment and fill in for production)
# DATABASE_URL=postgresql://retail:retail_pass@localhost:5432/retail_db

# ── Redis (optional — event bus is disabled gracefully when Redis is absent) ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ── Security ──────────────────────────────────────────────────────────────────
# CHANGE THIS before any deployment — app will warn if this is still "change-me"
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── MLflow (optional) ─────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=retail_multi_agent

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
